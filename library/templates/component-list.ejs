import React, { useState, useEffect } from 'react';

interface <%= modelName %> {
  id: number;
<% fields.forEach(function(field) { %>
  <%= field.name %>: <%= field.tsType || 'string' %>;
<% }); %>
  created_at: string;
  updated_at: string;
}

interface <%= modelName %>ListProps {
  onSelect?: (item: <%= modelName %>) => void;
  onEdit?: (item: <%= modelName %>) => void;
  onDelete?: (item: <%= modelName %>) => void;
}

export const <%= modelName %>List: React.FC<<%= modelName %>ListProps> = ({
  onSelect,
  onEdit,
  onDelete,
}) => {
  const [items, setItems] = useState<<%= modelName %>[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
<% if (pagination) { %>
  const [page, setPage] = useState(1);
  const [totalPages, setTotalPages] = useState(1);
<% } %>

  useEffect(() => {
    fetchItems();
  }, [<% if (pagination) { %>page<% } %>]);

  const fetchItems = async () => {
    try {
      setLoading(true);
<% if (pagination) { %>
      const response = await fetch(`/<%= tableize(modelName) %>?page=${page}`);
<% } else { %>
      const response = await fetch('/<%= tableize(modelName) %>');
<% } %>
      if (!response.ok) throw new Error('Failed to fetch');
      const data = await response.json();
<% if (pagination) { %>
      setItems(data.items);
      setTotalPages(data.total_pages);
<% } else { %>
      setItems(data);
<% } %>
    } catch (err) {
      setError(err instanceof Error ? err.message : 'An error occurred');
    } finally {
      setLoading(false);
    }
  };

  const handleDelete = async (item: <%= modelName %>) => {
    if (!confirm('Are you sure you want to delete this item?')) return;

    try {
      const response = await fetch(`/<%= tableize(modelName) %>/${item.id}`, {
        method: 'DELETE',
        headers: {
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '',
        },
      });

      if (response.ok) {
        setItems(items.filter(i => i.id !== item.id));
        onDelete?.(item);
      }
    } catch (err) {
      setError('Failed to delete item');
    }
  };

  if (loading) {
<% if (cssFramework === 'tailwind') { %>
    return <div className="flex justify-center p-8"><span className="animate-spin">Loading...</span></div>;
<% } else if (cssFramework === 'bootstrap') { %>
    return <div className="d-flex justify-content-center p-4"><div className="spinner-border" role="status"><span className="visually-hidden">Loading...</span></div></div>;
<% } else { %>
    return <div>Loading...</div>;
<% } %>
  }

  if (error) {
<% if (cssFramework === 'tailwind') { %>
    return <div className="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">{error}</div>;
<% } else if (cssFramework === 'bootstrap') { %>
    return <div className="alert alert-danger">{error}</div>;
<% } else { %>
    return <div className="error">{error}</div>;
<% } %>
  }

  return (
<% if (cssFramework === 'tailwind') { %>
    <div className="space-y-4">
      <div className="overflow-x-auto">
        <table className="min-w-full divide-y divide-gray-200">
          <thead className="bg-gray-50">
            <tr>
<% fields.forEach(function(field) { %>
              <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                <%= humanize(field.name) %>
              </th>
<% }); %>
              <th className="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                Actions
              </th>
            </tr>
          </thead>
          <tbody className="bg-white divide-y divide-gray-200">
            {items.map((item) => (
              <tr
                key={item.id}
                className="hover:bg-gray-50 cursor-pointer"
                onClick={() => onSelect?.(item)}
              >
<% fields.forEach(function(field) { %>
                <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  {item.<%= field.name %>}
                </td>
<% }); %>
                <td className="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
                  <button
                    onClick={(e) => { e.stopPropagation(); onEdit?.(item); }}
                    className="text-indigo-600 hover:text-indigo-900"
                  >
                    Edit
                  </button>
                  <button
                    onClick={(e) => { e.stopPropagation(); handleDelete(item); }}
                    className="text-red-600 hover:text-red-900"
                  >
                    Delete
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
<% if (pagination) { %>

      <div className="flex justify-between items-center mt-4">
        <button
          onClick={() => setPage(p => Math.max(1, p - 1))}
          disabled={page === 1}
          className="px-4 py-2 border rounded disabled:opacity-50"
        >
          Previous
        </button>
        <span>Page {page} of {totalPages}</span>
        <button
          onClick={() => setPage(p => Math.min(totalPages, p + 1))}
          disabled={page === totalPages}
          className="px-4 py-2 border rounded disabled:opacity-50"
        >
          Next
        </button>
      </div>
<% } %>
    </div>
<% } else if (cssFramework === 'bootstrap') { %>
    <div>
      <table className="table table-hover">
        <thead>
          <tr>
<% fields.forEach(function(field) { %>
            <th><%= humanize(field.name) %></th>
<% }); %>
            <th className="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          {items.map((item) => (
            <tr key={item.id} onClick={() => onSelect?.(item)} style={{ cursor: 'pointer' }}>
<% fields.forEach(function(field) { %>
              <td>{item.<%= field.name %>}</td>
<% }); %>
              <td className="text-end">
                <button
                  onClick={(e) => { e.stopPropagation(); onEdit?.(item); }}
                  className="btn btn-sm btn-outline-primary me-2"
                >
                  Edit
                </button>
                <button
                  onClick={(e) => { e.stopPropagation(); handleDelete(item); }}
                  className="btn btn-sm btn-outline-danger"
                >
                  Delete
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
<% if (pagination) { %>

      <nav>
        <ul className="pagination justify-content-center">
          <li className={`page-item ${page === 1 ? 'disabled' : ''}`}>
            <button className="page-link" onClick={() => setPage(p => p - 1)}>Previous</button>
          </li>
          <li className="page-item disabled">
            <span className="page-link">Page {page} of {totalPages}</span>
          </li>
          <li className={`page-item ${page === totalPages ? 'disabled' : ''}`}>
            <button className="page-link" onClick={() => setPage(p => p + 1)}>Next</button>
          </li>
        </ul>
      </nav>
<% } %>
    </div>
<% } else { %>
    <div>
      <table>
        <thead>
          <tr>
<% fields.forEach(function(field) { %>
            <th><%= humanize(field.name) %></th>
<% }); %>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {items.map((item) => (
            <tr key={item.id} onClick={() => onSelect?.(item)}>
<% fields.forEach(function(field) { %>
              <td>{item.<%= field.name %>}</td>
<% }); %>
              <td>
                <button onClick={(e) => { e.stopPropagation(); onEdit?.(item); }}>Edit</button>
                <button onClick={(e) => { e.stopPropagation(); handleDelete(item); }}>Delete</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
<% } %>
  );
};

export default <%= modelName %>List;
